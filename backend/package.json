{
  "author": "Chellys Kitchen",
  "description": "Backend API for Chellys Kitchen - slim Node HTTP server; JSON file store by default, Postgres via Prisma when DATABASE_URL is set",
  "engines": {
    "node": ">=22.18.0"
  },
  "keywords": [
    "api",
    "recipes"
  ],
  "license": "MIT",
  "main": "server.mts",
  "name": "chellys-kitchen-backend",
  "scripts": {
    "dev": "node --watch server.mts",
    "start": "node server.mts",
    "start:render": "prisma migrate deploy && node server.mts",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "version": "1.0.0",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "typescript": "~6.0.3"
  }
}
