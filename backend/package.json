{
  "author": "Chellys Kitchen",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2"
  },
  "description": "Backend API for Chellys Kitchen - Fastify + TypeScript",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "nodemon": "^3.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4"
  },
  "keywords": [
    "fastify",
    "typescript",
    "api",
    "recipes"
  ],
  "license": "MIT",
  "main": "dist/server.js",
  "name": "chellys-kitchen-backend",
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "scripts": {
    "build": "prisma generate && tsc || true",
    "dev": "nodemon --exec ts-node src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node dist/prisma/seed.js",
    "start": "prisma generate && prisma migrate deploy && node dist/server.js",
    "test": "tsx --test src/**/*.test.ts"
  },
  "version": "1.0.0"
}
