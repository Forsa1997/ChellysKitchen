{
  "author": "Chellys Kitchen",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2"
  },
  "description": "Backend API for Chellys Kitchen - Fastify + TypeScript",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.4",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "fastify",
    "typescript",
    "api",
    "recipes"
  ],
  "license": "MIT",
  "main": "dist/server.js",
  "name": "chellys-kitchen-backend",
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "scripts": {
    "build": "prisma generate && tsc && node build.js",
    "dev": "node --watch server.mjs",
    "dev:prisma": "nodemon --exec ts-node src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node dist/prisma/seed.js",
    "start": "node dist/server.js",
    "start:render": "node server.mjs",
    "test": "node --test src/persistence.test.mjs src/cors.test.mjs src/uploads.test.mjs src/queryRecipes.test.mjs src/randomRecipe.test.mjs src/backup.test.mjs test/server.smoke.test.mjs"
  },
  "version": "1.0.0"
}
