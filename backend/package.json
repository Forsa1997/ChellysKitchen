{
  "author": "Chellys Kitchen",
  "description": "Backend API for Chellys Kitchen - slim Node HTTP server; JSON file store by default, Postgres via Prisma when DATABASE_URL is set",
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "api",
    "recipes"
  ],
  "license": "MIT",
  "main": "server.mjs",
  "name": "chellys-kitchen-backend",
  "scripts": {
    "dev": "node --watch server.mjs",
    "start": "node server.mjs",
    "start:render": "prisma migrate deploy && node server.mjs",
    "test": "node --test",
    "postinstall": "prisma generate"
  },
  "version": "1.0.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0"
  }
}
